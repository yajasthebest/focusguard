{
  "expo": {
    "name": "FocusGuard",
    "slug": "focusguard",
    "version": "1.0.0",
    "orientation": "portrait",
    "android": {
      "package": "com.focusguard",
      "adaptiveIcon": {
        "backgroundColor": "#080808"
      },
      "permissions": [
        "android.permission.BIND_ACCESSIBILITY_SERVICE"
      ]
    },
    "plugins": [
      "@react-native-google-signin/google-signin"
    ]
  }
}
